    {
      "cell_type": "code",
      "source": [
        "#Task 2: Flatten images and normalize pixel values, print shapes before/after\n",
        "print(\"Before preprocessing:\")\n",
        "print(\"x_train shape:\", x_train.shape)\n",
        "print(\"x_test shape:\", x_test.shape)\n",
        "\n",
        "x_train_norm = x_train.astype('float32') / 255.0\n",
        "x_test_norm = x_test.astype('float32') / 255.0\n",
        "\n",
        "x_trainf = x_train_norm.reshape(-1, 784)\n",
        "x_testf = x_test_norm.reshape(-1, 784)\n",
        "\n",
        "print(\"\\nAfter preprocessing:\")\n",
        "print(\"x_train flat shape:\", x_trainf.shape)\n",
        "print(\"x_test flat shape:\", x_testf.shape)"
      ],
