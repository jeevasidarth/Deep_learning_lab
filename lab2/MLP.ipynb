        "#Task 7 Step 6: Evaluate optimized model on testing dataset\n",
        "y_pred_opt_prob = optimized_model.predict(x_testf)\n",
        "y_pred_opt = np.argmax(y_pred_opt_prob, axis=1)\n",
        "\n",
        "opt_accuracy = accuracy_score(y_true, y_pred_opt)\n",
        "opt_precision = precision_score(y_true, y_pred_opt, average='weighted')\n",
        "opt_recall = recall_score(y_true, y_pred_opt, average='weighted')\n",
        "opt_f1 = f1_score(y_true, y_pred_opt, average='weighted')\n",
        "\n",
        "print(f\"Optimized Accuracy:  {opt_accuracy:.4f}\")\n",
        "print(f\"Optimized Precision: {opt_precision:.4f}\")\n",
        "print(f\"Optimized Recall:    {opt_recall:.4f}\")\n",
        "print(f\"Optimized F1-score:  {opt_f1:.4f}\")\n",
        "\n",
        "cm_opt = confusion_matrix(y_true, y_pred_opt)\n",
        "\n",
        "fig, ax = plt.subplots(figsize=(10, 8))\n",
